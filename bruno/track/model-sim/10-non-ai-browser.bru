meta {
  name: post track event - Non-AI Browser
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/functions/v1/track
  body: json
  auth: none
}

headers {
  Accept: application/json
  Authorization: Bearer {{publishableKey}}
  apikey: {{publishableKey}}
  Content-Type: application/json
}

body:json {
  {
    "token": "{{trackToken}}",
    "pageUrl": "{{pageUrl}}",
    "pagePath": "{{pagePath}}",
    "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/123.0.0.0 Safari/537.36",
    "source": "script"
  }
}

tests {
  test("returns accepted", function () {
    expect(res.getStatus()).to.equal(202);
  });

  test("returns ok true", function () {
    const body = res.getBody();
    expect(body.ok).to.equal(true);
  });
}
